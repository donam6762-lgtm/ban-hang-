<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="SudesCraft - Cua hang thu cong cao cap voi gom su, nen mui, do trang tri va qua tang. Dat hang nhanh, giao hang toan quoc.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://example.com/">
  <title>Sudes Craft | Cua Hang Thu Cong Cao Cap</title>
  <style>
    :root {
      --bg: #f5efe7;
      --surface: #fffaf4;
      --surface-soft: #fdf6ef;
      --text: #2f261f;
      --muted: #7f6e60;
      --line: #e6d7c9;
      --primary: #8b5e3c;
      --primary-strong: #72492d;
      --accent: #d2ab8d;
      --good: #3d7844;
      --danger: #b04033;
      --shadow-md: 0 10px 30px rgba(63, 39, 22, 0.11);
      --radius-lg: 22px;
      --radius-md: 14px;
      --container: min(1200px, 100% - 36px);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: "Segoe UI", Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(1300px 480px at 100% -10%, #efdccf 0%, rgba(239, 220, 207, 0) 64%),
        radial-gradient(1000px 420px at -10% 0%, #f2e0d2 0%, rgba(242, 224, 210, 0) 62%),
        var(--bg);
      line-height: 1.55;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      display: block;
      max-width: 100%;
    }

    .container {
      width: var(--container);
      margin: 0 auto;
    }

    .btn {
      border: 0;
      border-radius: 999px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 600;
      padding: 10px 16px;
      transition: transform 0.2s ease, background 0.2s ease, opacity 0.2s ease;
      white-space: nowrap;
    }

    .btn:hover {
      transform: translateY(-1px);
    }

    .btn-primary {
      background: var(--primary);
      color: #fff;
    }

    .btn-primary:hover {
      background: var(--primary-strong);
    }

    .btn-soft {
      background: #f3e4d7;
      color: var(--primary-strong);
      border: 1px solid #e6cdb8;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface);
      color: var(--muted);
      font-size: 13px;
      padding: 7px 12px;
    }

    .section-title {
      font-size: clamp(24px, 3.2vw, 34px);
      line-height: 1.2;
    }

    .section-sub {
      color: var(--muted);
      margin-top: 6px;
      font-size: 14px;
    }

    .announce {
      background: #2f261f;
      color: #f9ede2;
      font-size: 13px;
    }

    .announce .container {
      min-height: 38px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 20;
      border-bottom: 1px solid var(--line);
      background: rgba(245, 239, 231, 0.9);
      backdrop-filter: blur(7px);
    }

    .header-inner {
      min-height: 76px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--primary);
      font-weight: 700;
      letter-spacing: 0.4px;
    }

    .brand-logo {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      object-fit: cover;
      border: 1px solid #d7c4b5;
      background: #fff8ef;
    }

    .brand-text {
      font-size: 24px;
      line-height: 1;
    }

    .footer-logo {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
      color: #4d3a2c;
      font-weight: 700;
    }

    .footer-logo .brand-logo {
      width: 34px;
      height: 34px;
      border-radius: 9px;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 18px;
      color: var(--muted);
      font-size: 14px;
    }

    .nav a {
      padding: 5px 4px;
      border-bottom: 2px solid transparent;
      transition: border-color 0.2s ease, color 0.2s ease;
    }

    .nav a:hover {
      color: var(--text);
      border-color: #ccb39d;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .category-bar {
      min-height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-top: 1px solid #eadbce;
    }

    .category-left {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
    }

    .cat-dropdown {
      position: relative;
    }

    .cat-dropdown summary {
      list-style: none;
      border: 1px solid #dfc5af;
      border-radius: 12px;
      background: #fff8f1;
      color: #5f402a;
      padding: 9px 14px;
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      user-select: none;
    }

    .cat-dropdown summary::-webkit-details-marker {
      display: none;
    }

    .cat-menu {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      min-width: 220px;
      border: 1px solid #ead8c9;
      border-radius: 12px;
      background: #fff;
      box-shadow: var(--shadow-md);
      padding: 8px;
      display: grid;
      gap: 4px;
      z-index: 25;
    }

    .cat-menu a {
      padding: 8px 10px;
      border-radius: 8px;
      color: #5f4a3a;
      font-size: 14px;
    }

    .cat-menu a:hover {
      background: #f8ece1;
      color: #3f2d1f;
    }

    .main-menu {
      display: flex;
      align-items: center;
      gap: 16px;
      color: #5f4a3a;
      font-weight: 600;
      font-size: 15px;
      flex-wrap: wrap;
    }

    .main-menu a {
      padding: 5px 0;
      border-bottom: 2px solid transparent;
      transition: color 0.2s ease, border-color 0.2s ease;
    }

    .main-menu a:hover {
      color: #3f2d1f;
      border-color: #cba78a;
    }

    .promo-chip {
      border: 1px solid #e8c8ac;
      border-radius: 12px;
      background: #fffaf5;
      color: #ad6430;
      padding: 8px 12px;
      font-size: 14px;
      font-weight: 700;
      white-space: nowrap;
    }

    main {
      padding-bottom: 24px;
    }

    .hero {
      padding: 28px 0 24px;
    }

    .hero-banner {
      padding: 14px 0 8px;
    }

    .hero-banner .container {
      width: min(1280px, 100% - 20px);
    }

    .banner-slider {
      position: relative;
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-md);
      background: #ebdccf;
    }

    .banner-track {
      display: flex;
      width: 100%;
      transition: transform 0.9s cubic-bezier(0.22, 0.61, 0.36, 1);
      will-change: transform;
    }

    .banner-slide {
      flex: 0 0 100%;
      position: relative;
      min-height: 360px;
      isolation: isolate;
    }

    .banner-slide img {
      width: 100%;
      height: 360px;
      object-fit: cover;
      display: block;
    }

    .banner-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(39, 24, 15, 0.48) 5%, rgba(39, 24, 15, 0.18) 46%, rgba(39, 24, 15, 0.12) 100%);
      z-index: 1;
    }

    .banner-content {
      position: absolute;
      left: 20px;
      bottom: 18px;
      z-index: 2;
      color: #fff;
      max-width: 520px;
      display: grid;
      gap: 8px;
    }

    .banner-title {
      font-size: clamp(22px, 4.4vw, 44px);
      line-height: 1.05;
      text-shadow: 0 3px 14px rgba(0, 0, 0, 0.24);
    }

    .banner-sub {
      font-size: 14px;
      color: #f7e9dd;
    }

    .banner-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.7);
      background: rgba(0, 0, 0, 0.24);
      color: #fff;
      cursor: pointer;
      z-index: 3;
      font-size: 22px;
      line-height: 1;
    }

    .banner-nav:hover {
      background: rgba(0, 0, 0, 0.4);
    }

    .banner-nav.prev {
      left: 10px;
    }

    .banner-nav.next {
      right: 10px;
    }

    .banner-dots {
      position: absolute;
      bottom: 12px;
      right: 14px;
      z-index: 3;
      display: flex;
      gap: 7px;
    }

    .banner-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      border: 0;
      cursor: pointer;
      background: rgba(255, 255, 255, 0.52);
    }

    .banner-dot.active {
      background: #fff;
      transform: scale(1.1);
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.08fr 0.92fr;
      gap: 18px;
      align-items: stretch;
    }

    .hero-main {
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background:
        radial-gradient(700px 200px at 0% 0%, #fff5ea 0%, rgba(255, 245, 234, 0) 60%),
        var(--surface);
      box-shadow: var(--shadow-md);
      padding: 34px;
      display: grid;
      gap: 16px;
    }

    .hero-main h1 {
      font-size: clamp(31px, 4.5vw, 58px);
      line-height: 1.05;
      max-width: 700px;
    }

    .hero-main p {
      color: var(--muted);
      max-width: 580px;
      font-size: 15px;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 8px;
    }

    .hero-side {
      border-radius: var(--radius-lg);
      border: 1px solid #d9bfa9;
      background:
        linear-gradient(120deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0)),
        radial-gradient(circle at 20% 24%, #f9e7da, #e2c4a9 70%);
      box-shadow: var(--shadow-md);
      padding: 20px;
      display: grid;
      gap: 14px;
      align-content: end;
      min-height: 330px;
    }

    .hero-side-card {
      border: 1px solid rgba(255, 255, 255, 0.7);
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.55);
      padding: 12px;
      color: #5d402a;
      display: grid;
      gap: 6px;
      backdrop-filter: blur(2px);
    }

    .trust {
      padding: 6px 0 10px;
    }

    .trust-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .trust-item {
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: var(--surface-soft);
      padding: 14px 16px;
      color: #6d5d4f;
      font-size: 14px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .shop {
      padding: 30px 0 26px;
    }

    .shop > .container {
      border: 1px solid #eadbce;
      border-radius: 22px;
      background:
        linear-gradient(180deg, #fffdfb 0%, #fff9f4 100%);
      padding: 22px;
      box-shadow: 0 14px 28px rgba(71, 43, 23, 0.08);
    }

    .shop-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 12px;
      margin-bottom: 16px;
    }

    .search-hint {
      margin-top: 10px;
      min-height: 20px;
      color: #7f5c44;
      font-size: 13px;
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 16px;
    }

    .tags .chip {
      background: #fff;
      color: #6f5847;
      border-color: #e6d2c0;
    }

    .toolbar {
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: #fff;
      padding: 13px;
      display: grid;
      grid-template-columns: 1.45fr 1fr 1fr;
      gap: 10px;
      margin-bottom: 18px;
      box-shadow: 0 8px 24px rgba(75, 47, 29, 0.09);
    }

    .field,
    .select {
      width: 100%;
      font-size: 14px;
      color: var(--text);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 10px 12px;
      outline: none;
      background: #fffcf8;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .field:focus,
    .select:focus {
      border-color: #cca182;
      box-shadow: 0 0 0 3px rgba(204, 161, 130, 0.22);
    }

    .products {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 16px;
    }

    .product-card {
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--surface);
      box-shadow: var(--shadow-md);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      min-height: 360px;
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

    .product-card:hover {
      transform: translateY(-4px);
      border-color: #d9bfa8;
      box-shadow: 0 16px 26px rgba(71, 44, 24, 0.14);
    }

    .product-thumb {
      min-height: 176px;
      overflow: hidden;
      background:
        radial-gradient(circle at 20% 20%, #fff4ea, #f0dcc9 62%),
        linear-gradient(160deg, #f8ebdf, #ead2bc);
      border-bottom: 1px solid var(--line);
    }

    .product-thumb img {
      width: 100%;
      height: 176px;
      object-fit: cover;
    }

    .thumb-icon {
      min-height: 176px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 56px;
      color: #634730;
    }

    .product-content {
      flex: 1;
      padding: 14px;
      display: grid;
      gap: 9px;
    }

    .product-meta {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      font-size: 12px;
      color: var(--muted);
    }

    .product-name {
      font-size: 18px;
      line-height: 1.3;
      font-weight: 700;
    }

    .product-desc {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
      min-height: 42px;
    }

    .product-price {
      color: var(--good);
      font-weight: 700;
      font-size: 19px;
      margin-top: 3px;
    }

    .product-rating {
      font-size: 12px;
      color: #866247;
      font-weight: 600;
    }

    .stock-badge {
      font-size: 11px;
      border: 1px solid #d8c0ac;
      border-radius: 999px;
      color: #6e4f39;
      background: #fff7f0;
      padding: 3px 8px;
      width: fit-content;
    }

    .product-actions {
      margin-top: auto;
      display: grid;
      gap: 7px;
    }

    .detail-btn {
      width: 100%;
      border-radius: 10px;
      padding: 9px 12px;
      font-weight: 700;
    }

    .add-btn {
      width: 100%;
      border-radius: 10px;
      padding: 10px 12px;
    }

    .info {
      padding: 8px 0 30px;
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .info-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      box-shadow: 0 10px 22px rgba(70, 41, 23, 0.1);
      padding: 18px;
    }

    .info-card h3 {
      font-size: 18px;
    }

    .info-card p {
      color: var(--muted);
      margin-top: 8px;
      font-size: 14px;
      line-height: 1.6;
    }

    .newsletter {
      margin: 0 0 30px;
      border: 1px solid #dcc2ad;
      border-radius: 20px;
      padding: 24px;
      background: linear-gradient(145deg, #ecd5c2, #f5e6d9);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 14px;
      box-shadow: 0 14px 30px rgba(78, 48, 29, 0.14);
    }

    .newsletter p {
      color: #6e4f3b;
      font-size: 14px;
    }

    .testimonials {
      padding: 4px 0 22px;
    }

    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .review-card {
      border: 1px solid var(--line);
      border-radius: 14px;
      background: #fffefc;
      padding: 14px;
      box-shadow: 0 8px 20px rgba(63, 39, 22, 0.08);
      display: grid;
      gap: 8px;
    }

    .review-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      color: #7a6555;
    }

    .stars {
      color: #f2a93f;
      letter-spacing: 1px;
      font-size: 13px;
    }

    .policy-area {
      padding: 0 0 24px;
    }

    .policy-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .policy-card {
      border: 1px solid #e4d3c3;
      border-radius: 14px;
      background: #fff;
      padding: 14px 12px;
      font-size: 13px;
      color: #6f5c4c;
      display: grid;
      gap: 5px;
    }

    .policy-card strong {
      color: #3d2f24;
      font-size: 14px;
    }

    .contact-strip {
      padding: 0 0 20px;
    }

    .contact-box {
      border: 1px solid #e5d4c4;
      border-radius: 16px;
      background: #fffdf9;
      padding: 14px 16px;
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      color: #6f5d4d;
      font-size: 14px;
    }

    .site-footer {
      margin-top: 4px;
      border-top: 1px solid #ebded2;
      background: #fff;
    }

    .footer-top {
      border-bottom: 1px solid #f0e7de;
      padding: 12px 0;
      text-align: center;
      color: #7a6a5b;
      font-size: 13px;
      display: grid;
      gap: 6px;
    }

    .footer-company {
      font-weight: 600;
      color: #5f4d3f;
    }

    .footer-main {
      padding: 22px 0 20px;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
    }

    .footer-col h4 {
      margin-bottom: 10px;
      font-size: 21px;
      line-height: 1.15;
    }

    .footer-col li,
    .footer-col a,
    .footer-col p {
      color: #6b5a4b;
      font-size: 14px;
    }

    .footer-col ul {
      list-style: none;
      display: grid;
      gap: 6px;
    }

    .footer-col a:hover {
      color: #4c3b2d;
    }

    .pay-group {
      margin-top: 10px;
      display: grid;
      gap: 8px;
    }

    .pay-label {
      color: #4f3d2f;
      font-weight: 600;
      font-size: 14px;
    }

    .pay-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .pay-badge {
      min-width: 44px;
      border: 1px solid #eaded2;
      border-radius: 8px;
      padding: 5px 8px;
      background: #fff9f4;
      font-size: 11px;
      color: #5f4f41;
      text-align: center;
      font-weight: 600;
    }

    .social-list {
      display: flex;
      align-items: center;
      gap: 8px;
      margin: 4px 0 14px;
    }

    .social-icon {
      width: 28px;
      height: 28px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid #eaded2;
      background: #fff8f1;
      color: #5d4a3a;
      font-size: 13px;
      font-weight: 700;
    }

    .footer-sub-title {
      font-size: 28px;
      line-height: 1.12;
      color: #30261f;
      margin-bottom: 8px;
      max-width: 320px;
    }

    .subscribe-box {
      border: 1px solid #eaded2;
      border-radius: 999px;
      background: #fff;
      display: flex;
      align-items: center;
      overflow: hidden;
      max-width: 320px;
    }

    .subscribe-box input {
      border: 0;
      outline: 0;
      flex: 1;
      padding: 10px 12px;
      font-size: 14px;
      color: #423428;
    }

    .subscribe-box button {
      border: 0;
      border-left: 1px solid #efe4d8;
      background: #fff9f3;
      color: #5c4a3c;
      cursor: pointer;
      padding: 10px 14px;
      font-weight: 700;
    }

    .footer-bottom {
      border-top: 1px solid #f2e8df;
      min-height: 50px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
      color: #7a695a;
      font-size: 13px;
      padding: 10px 0 14px;
    }

    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(28, 20, 14, 0.45);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease;
      z-index: 39;
    }

    .overlay.open {
      opacity: 1;
      visibility: visible;
    }

