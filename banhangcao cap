    const state = {
      productById: new Map(PRODUCTS.map((p) => [p.id, p])),
      cart: loadCart(),
      couponCode: "",
      activeProductId: null,
      searchSuggestion: ""
    };

    function formatCurrency(value) {
      return `${money.format(value)} VND`;
    }

    function safeNumber(value, fallback = 0) {
      const n = Number(value);
      return Number.isFinite(n) ? n : fallback;
    }

    function normalizeText(value) {
      return String(value || "").trim().toLowerCase();
    }

    function normalizeForSearch(value) {
      return normalizeText(value)
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");
    }

    function productStock(product) {
      return safeNumber(product.stock, 8 + ((product.id * 3) % 15));
    }

    function productRating(product) {
      const rating = safeNumber(product.rating, 4.2 + (product.id % 3) * 0.2);
      return Math.min(5, Math.max(3.8, rating));
    }

    function productReviews(product) {
      return safeNumber(product.reviews, 18 + product.id * 7);
    }

    function findClosestKeyword(keyword) {
      if (!keyword) return "";
      const normalizedKeyword = normalizeForSearch(keyword);
      let best = "";
      let bestScore = Number.POSITIVE_INFINITY;

      PRODUCTS.forEach((product) => {
        const tokens = normalizeForSearch(product.name).split(/\s+/).filter(Boolean);
        tokens.forEach((token) => {
          const distance = Math.abs(token.length - normalizedKeyword.length) + (token.includes(normalizedKeyword) ? 0 : 1);
          if (distance < bestScore) {
            bestScore = distance;
            best = token;
          }
        });
      });

      return bestScore <= 4 ? best : "";
    }

    function loadCart() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return {};
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === "object" ? parsed : {};
      } catch {
        return {};
      }
    }

    function saveCart() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state.cart));
    }

    function cartEntries() {
      return Object.entries(state.cart).filter(([, qty]) => safeNumber(qty, 0) > 0);
    }

    function cartItemCount() {
      return cartEntries().reduce((sum, [, qty]) => sum + safeNumber(qty, 0), 0);
    }

    function cartSubtotal() {
      return cartEntries().reduce((sum, [id, qty]) => {
        const product = state.productById.get(safeNumber(id));
        return product ? sum + product.price * safeNumber(qty, 0) : sum;
      }, 0);
    }

    function shippingFee() {
      return cartItemCount() >= FREE_SHIP_ITEM_THRESHOLD ? 0 : SHIPPING_FEE;
    }

    function getCoupon() {
      const code = normalizeText(state.couponCode).toUpperCase();
      return COUPONS[code] || null;
    }

    function discountAmount(subtotal, ship) {
      const coupon = getCoupon();
      if (!coupon) return 0;
      if (coupon.type === "percent") {
        return Math.floor((subtotal * coupon.value) / 100);
      }
      const fixed = safeNumber(coupon.value, 0);
      return Math.min(subtotal + ship, fixed);
    }

    function updateSearchHints() {
      if (!els.searchHints) return;
      const keyword = normalizeText(els.searchInput.value);
      const top = PRODUCTS
        .filter((p) => !keyword || normalizeText(p.name).includes(keyword))
        .slice(0, 6);
      els.searchHints.innerHTML = top.map((p) => `<option value="${p.name}">`).join("");
    }

    function sortProducts(list, mode) {
      if (mode === "priceAsc") return [...list].sort((a, b) => a.price - b.price);
      if (mode === "priceDesc") return [...list].sort((a, b) => b.price - a.price);
      return list;
    }

    function filteredProducts() {
      const keyword = normalizeText(els.searchInput.value);
      const keywordNormalized = normalizeForSearch(keyword);
      const category = els.categoryFilter.value;
      const mode = els.sortFilter.value;

      const base = PRODUCTS.filter((product) => {
        const matchKeyword = normalizeForSearch(product.name).includes(keywordNormalized);
        const matchCategory = category === "all" || product.category === category;
        return matchKeyword && matchCategory;
      });

      if (base.length || !keywordNormalized) {
        state.searchSuggestion = "";
        return sortProducts(base, mode);
      }

      const suggestion = findClosestKeyword(keywordNormalized);
      state.searchSuggestion = suggestion;
      const suggestedList = PRODUCTS.filter((product) => {
        const matchKeyword = normalizeForSearch(product.name).includes(suggestion);
        const matchCategory = category === "all" || product.category === category;
        return matchKeyword && matchCategory;
      });

      return sortProducts(suggestedList, mode);
    }

    function productTemplate(product) {
      const thumb = product.image
        ? `<img src="${product.image}" alt="${product.name}" loading="lazy">`
        : `<span class="thumb-icon">${product.icon || "🛍️"}</span>`;
      const stock = productStock(product);
      const rating = productRating(product).toFixed(1);
      const reviews = productReviews(product);
      return `
        <article class="product-card">
          <div class="product-thumb">${thumb}</div>
          <div class="product-content">
            <div class="product-meta">
              <span>${product.category}</span>
              <span>Handmade</span>
            </div>
            <h3 class="product-name">${product.name}</h3>
            <p class="product-desc">${product.desc}</p>
            <span class="stock-badge">Con ${stock} san pham</span>
            <div class="product-rating">★ ${rating} (${reviews} danh gia)</div>
            <div class="product-price">${formatCurrency(product.price)}</div>
            <div class="product-actions">
              <button class="btn btn-primary add-btn" data-add="${product.id}" type="button">Them vao gio</button>
              <button class="btn btn-soft detail-btn" data-detail="${product.id}" type="button">Xem chi tiet</button>
            </div>
          </div>
        </article>
      `;
    }

    function cartItemTemplate(product, quantity) {
      const lineTotal = product.price * quantity;
      return `
        <article class="cart-item">
          <div class="cart-row">
            <strong>${product.name}</strong>
            <button class="remove-btn" data-remove="${product.id}" type="button">Xoa</button>
          </div>
          <div class="cart-row">
            <span>${formatCurrency(product.price)}</span>
            <input class="qty" type="number" min="1" max="99" value="${quantity}" data-qty="${product.id}">
          </div>
          <div class="cart-row">
            <span>Thanh tien</span>
            <strong>${formatCurrency(lineTotal)}</strong>
          </div>
        </article>
      `;
    }

    function productDetailTemplate(product) {
      const thumb = product.image
        ? `<img src="${product.image}" alt="${product.name}" loading="lazy">`
        : `<span class="thumb-icon">${product.icon || "🛍️"}</span>`;
      const stock = productStock(product);
      const rating = productRating(product).toFixed(1);
      const reviews = productReviews(product);
      return `
        <div class="product-thumb">${thumb}</div>
        <div class="detail-info">
          <h3 class="detail-title">${product.name}</h3>
          <div class="product-price">${formatCurrency(product.price)}</div>
          <div class="detail-list">
            <span>Danh muc: ${product.category}</span>
            <span>Ton kho: ${stock} san pham</span>
            <span>Danh gia: ★ ${rating} (${reviews} danh gia)</span>
            <span>Doi tra: 7 ngay neu loi nha san xuat</span>
            <span>Giao nhanh: Noi thanh 4h - Toan quoc 2-5 ngay</span>
          </div>
          <p>${product.desc}</p>
          <div class="detail-review-list">
            <strong>Review gan day</strong>
            <span>"Dong goi dep, san pham rat chac tay." - Khach Hang A</span>
            <span>"Mui huong de chiu, dung lam qua rat hop." - Khach Hang B</span>
          </div>
        </div>
      `;
    }

    function renderProducts() {
      const list = filteredProducts();
      updateSearchHints();
      if (els.searchHint) {
        els.searchHint.textContent = state.searchSuggestion
          ? `Khong tim thay ket qua chinh xac. Goi y: "${state.searchSuggestion}".`
          : "";
      }
      if (!list.length) {
        els.productList.innerHTML = '<div class="empty-state">Khong tim thay san pham phu hop.</div>';
        return;
      }
      els.productList.innerHTML = list.map(productTemplate).join("");
    }

    function renderCart() {
      const entries = cartEntries();
      if (!entries.length) {
        els.cartList.innerHTML = '<div class="empty-state">Gio hang dang trong.</div>';
      } else {
        els.cartList.innerHTML = entries.map(([id, qty]) => {
          const product = state.productById.get(safeNumber(id));
          return product ? cartItemTemplate(product, safeNumber(qty, 1)) : "";
        }).join("");
      }

      const subtotal = cartSubtotal();
      const ship = shippingFee();
      const discount = discountAmount(subtotal, ship);
      const finalTotal = Math.max(0, subtotal + ship - discount);
      els.subtotal.textContent = formatCurrency(subtotal);
      els.shipping.textContent = formatCurrency(ship);
      els.discount.textContent = `-${formatCurrency(discount)}`;
      els.total.textContent = formatCurrency(finalTotal);
      els.cartBadge.textContent = `${cartItemCount()} san pham`;
      if (els.couponNote) {
        const coupon = getCoupon();
        els.couponNote.textContent = coupon
          ? `Da ap dung ${state.couponCode.toUpperCase()} - ${coupon.label}.`
          : "Ma hop le: SAVE10, FREESHIP, GIFT50";
      }
    }

    function syncUI() {
      renderProducts();
      renderCart();
    }

    function addToCart(productId) {
      const id = String(productId);
      const currentQty = safeNumber(state.cart[id], 0);
      state.cart[id] = Math.min(99, currentQty + 1);
      saveCart();
      renderCart();
    }

    function removeFromCart(productId) {
      delete state.cart[String(productId)];
      saveCart();
      renderCart();
    }

    function updateQuantity(productId, quantity) {
      const id = String(productId);
      const qty = Math.floor(safeNumber(quantity, 0));
      if (qty < 1) {
        removeFromCart(id);
        return;
      }
      state.cart[id] = Math.min(99, qty);
      saveCart();
      renderCart();
    }

    function applyCoupon() {
      const inputCode = normalizeText(els.couponInput.value).toUpperCase();
      if (!inputCode) {
        state.couponCode = "";
        renderCart();
        return;
      }
      if (!COUPONS[inputCode]) {
        els.couponNote.textContent = "Ma khong hop le.";
        return;
      }
      state.couponCode = inputCode;
      renderCart();
    }

    function openCart() {
      els.cartDrawer.classList.add("open");
      els.overlay.classList.add("open");
      syncBodyScrollLock();
    }

    function closeCart() {
      els.cartDrawer.classList.remove("open");
      els.overlay.classList.remove("open");
      syncBodyScrollLock();
    }

    function syncBodyScrollLock() {
      const hasOpenLayer =
        els.cartDrawer.classList.contains("open") ||
        els.checkoutModal.classList.contains("open") ||
        els.productModal.classList.contains("open");
      document.body.style.overflow = hasOpenLayer ? "hidden" : "";
    }

    function clearFormErrors() {
      els.formError.textContent = "";
      els.buyerNameError.textContent = "";
      els.buyerPhoneError.textContent = "";
      els.buyerEmailError.textContent = "";
      els.buyerAddressError.textContent = "";
    }

    function validateCheckoutForm() {
      clearFormErrors();

      const name = normalizeText(els.buyerName.value);
      const phone = normalizeText(els.buyerPhone.value);
      const email = normalizeText(els.buyerEmail.value);
      const address = normalizeText(els.buyerAddress.value);
      const note = els.buyerNote.value.trim();
      const paymentMethod = els.paymentMethod.value;
      let valid = true;

      if (name.length < 2) {
        els.buyerNameError.textContent = "Vui long nhap ho ten hop le.";
        valid = false;
      }

      if (!/^(\+84|0)\d{9,10}$/.test(phone)) {
        els.buyerPhoneError.textContent = "So dien thoai khong hop le.";
        valid = false;
      }

      if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        els.buyerEmailError.textContent = "Email khong dung dinh dang.";
        valid = false;
      }

      if (address.length < 8) {
        els.buyerAddressError.textContent = "Dia chi qua ngan, vui long nhap day du.";
        valid = false;
      }

      if (!valid) {
        els.formError.textContent = "Vui long kiem tra lai thong tin nguoi mua.";
        return null;
      }

      return { name, phone, email, address, note, paymentMethod };
    }

    function fillCheckoutSummary() {
      const subtotal = cartSubtotal();
      const ship = shippingFee();
      const discount = discountAmount(subtotal, ship);
      const finalTotal = Math.max(0, subtotal + ship - discount);
      els.checkoutItems.textContent = String(cartItemCount());
      els.checkoutSubtotal.textContent = formatCurrency(subtotal);
      els.checkoutShipping.textContent = formatCurrency(ship);
      els.checkoutDiscount.textContent = `-${formatCurrency(discount)}`;
      els.checkoutTotal.textContent = formatCurrency(finalTotal);
    }

    function openProductModal(productId) {
      const product = state.productById.get(safeNumber(productId));
      if (!product) return;
      state.activeProductId = product.id;
      els.productDetailBody.innerHTML = productDetailTemplate(product);
      els.productModal.classList.add("open");
      els.productBackdrop.classList.add("open");
      syncBodyScrollLock();
    }

    function closeProductModal() {
      state.activeProductId = null;
      els.productModal.classList.remove("open");
      els.productBackdrop.classList.remove("open");
      syncBodyScrollLock();
    }

    function hasRealUrl(url) {
      const value = String(url || "").trim();
      return /^https?:\/\//i.test(value) && !value.includes("PASTE_");
    }

    function withTimeout(promise, timeoutMs = 12000) {
      return new Promise((resolve, reject) => {
        const timer = setTimeout(() => reject(new Error("Timeout khi gui du lieu.")), timeoutMs);
        promise
          .then((value) => {
            clearTimeout(timer);
            resolve(value);
          })
          .catch((err) => {
            clearTimeout(timer);
            reject(err);
          });
      });
    }

    function buildOrderPayload({ buyerInfo, orderId, subtotal, ship, total, discount, couponCode }) {
      const items = cartEntries().map(([id, qty]) => {
        const product = state.productById.get(safeNumber(id));
        return product
          ? {
            id: product.id,
            name: product.name,
            category: product.category,
            price: product.price,
            quantity: safeNumber(qty, 1),
            lineTotal: product.price * safeNumber(qty, 1)
          }
          : null;
      }).filter(Boolean);

      return {
        source: "SudesCraft Web",
        createdAt: new Date().toISOString(),
        orderId,
        notifications: {
          adminEmail: INTEGRATIONS.adminEmail || ""
        },
        buyer: {
          name: buyerInfo.name,
          phone: buyerInfo.phone,
          email: buyerInfo.email,
          address: buyerInfo.address,
          note: buyerInfo.note,
          paymentMethod: buyerInfo.paymentMethod
        },
        summary: {
          itemCount: cartItemCount(),
          subtotal,
          shippingFee: ship,
          discount,
          couponCode,
          total
        },
        items
      };
    }

    async function postJson(url, payload) {
      const response = await withTimeout(
        fetch(url, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        }),
        INTEGRATIONS.requestTimeoutMs
      );

      if (!response.ok) {
        throw new Error(`Gui that bai: ${response.status}`);
      }
      return response;
    }

    async function sendOrderToIntegrations(payload) {
      if (!hasRealUrl(INTEGRATIONS.googleAppsScriptUrl)) {
        throw new Error("Ban chua dien Google Apps Script URL.");
      }

      const jobs = [
        postJson(INTEGRATIONS.googleAppsScriptUrl, payload)
      ];

      if (hasRealUrl(INTEGRATIONS.zaloWebhookUrl)) {
        jobs.push(postJson(INTEGRATIONS.zaloWebhookUrl, payload));
      }

      const results = await Promise.allSettled(jobs);
      const failed = results.filter((r) => r.status === "rejected");
      if (failed.length) {
        throw failed[0].reason || new Error("Khong the gui du lieu don hang.");
      }
    }

    function openCheckoutModal() {
      if (!cartEntries().length) {
        alert("Gio hang dang trong.");
        return;
      }
      fillCheckoutSummary();
      closeCart();
      els.checkoutModal.classList.add("open");
      els.checkoutBackdrop.classList.add("open");
      syncBodyScrollLock();
    }

    function closeCheckoutModal() {
      els.checkoutModal.classList.remove("open");
      els.checkoutBackdrop.classList.remove("open");
      syncBodyScrollLock();
    }

    function debounce(fn, delay = 180) {
      let timer = null;
      return (...args) => {
        clearTimeout(timer);
        timer = setTimeout(() => fn(...args), delay);
      };
    }

    function initBannerSlider() {
      if (!els.bannerSlider) return;
      const track = els.bannerSlider.querySelector(".banner-track");
      const slides = track ? [...track.querySelectorAll(".banner-slide")] : [];
      if (!slides.length) return;
      let activeIndex = 0;
      let autoplayTimer = null;
      const TRANSITION_CSS = "transform 0.9s cubic-bezier(0.22, 0.61, 0.36, 1)";

      const dots = slides.map((_, index) => {
        const dot = document.createElement("button");
        dot.type = "button";
        dot.className = "banner-dot";
        dot.setAttribute("aria-label", `Chuyen den slide ${index + 1}`);
        dot.addEventListener("click", () => {
          showSlide(index);
          restartAutoplay();
        });
        els.bannerDots.appendChild(dot);
        return dot;
      });

      function showSlide(index) {
        activeIndex = (index + slides.length) % slides.length;
        track.style.transform = `translate3d(-${activeIndex * 100}%, 0, 0)`;
        dots.forEach((dot, i) => {
          dot.classList.toggle("active", i === activeIndex);
        });
      }

      function nextSlide() {
        showSlide(activeIndex + 1);
      }

      function restartAutoplay() {
        clearInterval(autoplayTimer);
        autoplayTimer = setInterval(nextSlide, 3200);
      }

      els.bannerPrev.addEventListener("click", () => {
        showSlide(activeIndex - 1);
        restartAutoplay();
      });

      els.bannerNext.addEventListener("click", () => {
        nextSlide();
        restartAutoplay();
      });

      track.style.transition = TRANSITION_CSS;
      showSlide(0);
      restartAutoplay();
    }

    function bindEvents() {
      els.productList.addEventListener("click", (event) => {
        const btn = event.target.closest("[data-add]");
        if (btn) {
          addToCart(btn.getAttribute("data-add"));
          openCart();
          return;
        }
        const detailBtn = event.target.closest("[data-detail]");
        if (detailBtn) {
          openProductModal(detailBtn.getAttribute("data-detail"));
        }
      });

      els.cartList.addEventListener("click", (event) => {
        const removeBtn = event.target.closest("[data-remove]");
        if (!removeBtn) return;
        removeFromCart(removeBtn.getAttribute("data-remove"));
      });

      els.cartList.addEventListener("change", (event) => {
        const input = event.target.closest("[data-qty]");
        if (!input) return;
        updateQuantity(input.getAttribute("data-qty"), input.value);
      });

      const debouncedRender = debounce(renderProducts);
      els.searchInput.addEventListener("input", debouncedRender);
      els.categoryFilter.addEventListener("change", renderProducts);
      els.sortFilter.addEventListener("change", renderProducts);
      els.applyCouponBtn.addEventListener("click", applyCoupon);
      els.couponInput.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          applyCoupon();
        }
      });

      els.openCartBtn.addEventListener("click", openCart);
      els.openCartHeroBtn.addEventListener("click", openCart);
      els.closeCartBtn.addEventListener("click", closeCart);
      els.overlay.addEventListener("click", closeCart);
      els.closeCheckoutBtn.addEventListener("click", closeCheckoutModal);
      els.cancelCheckoutBtn.addEventListener("click", closeCheckoutModal);
      els.checkoutBackdrop.addEventListener("click", closeCheckoutModal);
      els.closeProductBtn.addEventListener("click", closeProductModal);
      els.productBackdrop.addEventListener("click", closeProductModal);
      els.addFromDetailBtn.addEventListener("click", () => {
        if (!state.activeProductId) return;
        addToCart(state.activeProductId);
        closeProductModal();
        openCart();
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeCart();
          closeCheckoutModal();
          closeProductModal();
        }
      });

      els.checkoutBtn.addEventListener("click", openCheckoutModal);
      els.buyerForm.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!cartEntries().length) {
          alert("Gio hang dang trong.");
          return;
        }

        const buyerInfo = validateCheckoutForm();
        if (!buyerInfo) {
          return;
        }

        const subtotal = cartSubtotal();
        const ship = shippingFee();
        const discount = discountAmount(subtotal, ship);
        const total = Math.max(0, subtotal + ship - discount);
        const orderId = `SC${Date.now().toString().slice(-6)}`;
        const submitBtn = els.buyerForm.querySelector('button[type="submit"]');
        const oldBtnText = submitBtn ? submitBtn.textContent : "";
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Dang gui...";
        }

        try {
          const payload = buildOrderPayload({
            buyerInfo,
            orderId,
            subtotal,
            ship,
            total,
            discount,
            couponCode: state.couponCode
          });
          await sendOrderToIntegrations(payload);

          alert(
            `Dat hang thanh cong!\n` +
            `Ma don: ${orderId}\n` +
            `Nguoi nhan: ${buyerInfo.name}\n` +
            `SDT: ${buyerInfo.phone}\n` +
            `Tong thanh toan: ${formatCurrency(total)}\n` +
            `Du lieu da gui ve Google Sheet + Email`
          );

          state.cart = {};
          state.couponCode = "";
          saveCart();
          renderCart();
          els.buyerForm.reset();
          clearFormErrors();
          closeCheckoutModal();
        } catch (error) {
          els.formError.textContent = `Gui don that bai: ${error.message || "Loi khong xac dinh"}`;
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = oldBtnText || "Xac nhan dat hang";
          }
        }
      });
    }

    function init() {
      bindEvents();
      initBannerSlider();
      updateSearchHints();
      syncUI();
      window.SUDES_TRACKING = {
        gaMeasurementId: "G-XXXXXXXXXX",
        metaPixelId: "000000000000000"
      };
    }

    init();
  </script>
</body>
</html>
