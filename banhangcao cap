    const COUPONS = {
      SAVE10: { type: "percent", value: 10, label: "Giam 10%" },
      FREESHIP: { type: "fixed", value: 30000, label: "Giam 30,000 VND phi ship" },
      GIFT50: { type: "fixed", value: 50000, label: "Giam 50,000 VND" }
